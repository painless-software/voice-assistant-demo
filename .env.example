# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+41xxxxxxxxx   # The Twilio number you purchased

# ── Google AI ─────────────────────────────────────────────────────────────────
# Option A: Google AI Studio key  (simplest for PoC)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Vertex AI  (uncomment and leave GOOGLE_API_KEY empty)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# (authenticate via: gcloud auth application-default login)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Public URL that Twilio can reach (ngrok / Cloud Run / etc.)
# Set automatically by start.sh when using ngrok, or fill in manually.
PUBLIC_URL=https://your-ngrok-or-domain.example.com

# ── Language ──────────────────────────────────────────────────────────────────
# Default language used for the greeting and until the caller's language is detected.
# Supported: de-CH  fr-CH  it-CH
DEFAULT_LANGUAGE=de-CH
